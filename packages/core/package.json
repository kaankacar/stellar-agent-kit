{
  "name": "@stellar-agent-kit/core",
  "version": "0.1.7",
  "description": "Core SDK: StellarAgentKit class, wallet abstraction, plugin registry, and AI framework adapters (LangChain, Vercel AI SDK, OpenAI, Anthropic).",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --dts --clean --format esm --out-dir dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^14.0.0-rc.3",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@langchain/core": "^0.3.0",
    "@stellar/freighter-api": "^6.0.0",
    "@creit.tech/stellar-wallets-kit": "^1.7.0",
    "ai": "^4.0.0",
    "openai": "^4.70.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@langchain/core": {
      "optional": true
    },
    "@stellar/freighter-api": {
      "optional": true
    },
    "@creit.tech/stellar-wallets-kit": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@langchain/core": "^0.3.0",
    "ai": "^4.0.0",
    "openai": "^4.70.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
