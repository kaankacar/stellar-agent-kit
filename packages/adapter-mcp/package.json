{
  "name": "@stellar-agent-kit/adapter-mcp",
  "version": "0.1.3",
  "description": "Expose StellarAgentKit as a Model Context Protocol (MCP) server. Each agent action becomes one MCP tool consumable by Claude Code, Cursor, and other MCP clients.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --dts --clean --format esm --out-dir dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "peerDependencies": {
    "@stellar-agent-kit/core": "workspace:*"
  },
  "devDependencies": {
    "@stellar-agent-kit/core": "workspace:*",
    "@stellar/stellar-sdk": "^14.0.0-rc.3",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
