{
  "name": "@stellar-agent-kit/plugin-defi",
  "version": "0.1.0-alpha.1",
  "description": "Stellar DeFi protocol actions: Blend (lending), Soroswap (DEX aggregator: Soroswap AMM, Phoenix, Aquarius, SDEX), Reflector (oracle).",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --dts --clean --format esm --out-dir dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^14.0.0-rc.3",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@stellar-agent-kit/core": "workspace:*",
    "@stellar-agent-kit/plugin-asset": "workspace:*"
  },
  "devDependencies": {
    "@stellar-agent-kit/core": "workspace:*",
    "@stellar-agent-kit/plugin-asset": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
