# Stellar wallet
STELLAR_SECRET_KEY=S...
STELLAR_NETWORK=testnet
# STELLAR_NETWORK=mainnet
# STELLAR_RPC_URL=https://your-mainnet-rpc

# LLM provider — set ONE
OPENROUTER_API_KEY=sk-or-v1-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Soroswap API key — REQUIRED for any swap / quote action (testnet AND mainnet
# are both gated). Get one at https://docs.soroswap.finance. Without it,
# SOROSWAP_QUOTE and SOROSWAP_SWAP will return "Forbidden resource".
SOROSWAP_API_KEY=

# Optional capabilities
BRAVE_API_KEY=
COINGECKO_API_KEY=
ETHERFUSE_API_KEY=

# Mainnet hardening — required to start the agent on mainnet
# STELLAR_AGENT_I_UNDERSTAND_THE_RISK=1
