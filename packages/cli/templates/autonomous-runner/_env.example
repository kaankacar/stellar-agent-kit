# Stellar wallet (testnet by default — generate via Keypair.random())
STELLAR_SECRET_KEY=S...

# OpenRouter API key — get free credits at https://openrouter.ai/keys
# The default model (nvidia/nemotron-3-super-120b-a12b:free) has no per-token cost.
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: switch to OpenAI / Anthropic by editing index.ts
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
