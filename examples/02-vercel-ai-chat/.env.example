# OpenAI key — used by the chat route's gpt-4o-mini call
OPENAI_API_KEY=sk-...

# Stellar wallet — server-side keypair the agent operates with.
# In production, generate via Keypair.random() once and persist securely.
STELLAR_SECRET_KEY=S...

# Optional — defaults to testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK=testnet
